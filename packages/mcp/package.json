{
  "name": "@luxxon/mcp",
  "version": "0.3.1",
  "description": "MCP server exposing Luxxon as agent-callable tools — open live sessions at any lat/lng, fetch frames, and read settlement.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "luxxon-mcp": "./dist/server.js"
  },
  "main": "./dist/server.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "build:mcpb": "bash scripts/build-mcpb.sh",
    "prepublishOnly": "rm -rf dist && pnpm build && chmod +x dist/server.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/luxxon-dev/luxxon-sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luxxon-dev/luxxon-sdk.git",
    "directory": "packages/mcp"
  },
  "keywords": [
    "luxxon",
    "mcp",
    "model-context-protocol",
    "agent",
    "vision",
    "ai"
  ],
  "dependencies": {
    "@luxxon/sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^25.8.0"
  },
  "engines": {
    "node": ">=18"
  }
}
