{
  "name": "luxxon-sdk",
  "version": "0.0.1",
  "private": true,
  "description": "Luxxon — TypeScript SDK + MCP server for the agent-native vision API",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm -r --filter './packages/*' test",
    "lint": "pnpm -r --filter './packages/*' lint"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=18"
  }
}
